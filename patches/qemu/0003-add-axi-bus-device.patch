diff --git a/hw/misc/axi-bus.c b/hw/misc/axi-bus.c
new file mode 100644
index 0000000000..14521bdf7f
--- /dev/null
+++ b/hw/misc/axi-bus.c
@@ -0,0 +1,504 @@
+/*
+ * AXI bus proxy device.
+ *
+ * This device intentionally does not implement virtio or any other endpoint
+ * protocol. It exposes a configurable MMIO window and is the QEMU-side anchor
+ * for forwarding register accesses to an external device model.
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "system/address-spaces.h"
+#include "system/device_tree.h"
+#include "system/memory.h"
+#include "hw/arm/fdt.h"
+#include "hw/arm/virt.h"
+#include "hw/i386/microvm.h"
+#include "hw/i386/x86.h"
+#include "hw/irq.h"
+#include "hw/qdev-properties.h"
+#include "hw/sysbus.h"
+#include "qemu/error-report.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+#include "qom/object.h"
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+#define TYPE_AXI_BUS "axi-bus"
+OBJECT_DECLARE_SIMPLE_TYPE(AxiBusState, AXI_BUS)
+
+typedef enum AxiBusRamAccess {
+    AXI_BUS_RAM_ACCESS_SHARED_MEM,
+    AXI_BUS_RAM_ACCESS_QEMU_MEDIATED,
+} AxiBusRamAccess;
+
+typedef enum AxiBusMsgKind {
+    AXI_BUS_MSG_HELLO = 1,
+    AXI_BUS_MSG_MEM_REGION = 2,
+    AXI_BUS_MSG_MMIO_READ = 3,
+    AXI_BUS_MSG_MMIO_READ_REPLY = 4,
+    AXI_BUS_MSG_MMIO_WRITE = 5,
+    AXI_BUS_MSG_IRQ_ASSERT = 6,
+    AXI_BUS_MSG_IRQ_DEASSERT = 7,
+    AXI_BUS_MSG_DMA_READ = 8,
+    AXI_BUS_MSG_DMA_READ_REPLY = 9,
+    AXI_BUS_MSG_DMA_WRITE = 10,
+    AXI_BUS_MSG_ERROR = 0xffff,
+} AxiBusMsgKind;
+
+typedef struct AxiBusMsgHeader {
+    uint16_t kind;
+    uint16_t flags;
+    uint32_t window_id;
+    uint64_t offset;
+    uint32_t length;
+} AxiBusMsgHeader;
+
+struct AxiBusState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion mmio;
+    uint64_t base;
+    uint64_t size;
+    uint32_t irq_num;
+    char *socket_path;
+    char *ram_access;
+    char *target;
+    AxiBusRamAccess ram_access_mode;
+    int sockfd;
+    bool socket_error_reported;
+    qemu_irq irq;
+};
+
+static bool axi_bus_io_all(int fd, void *buf, size_t len, bool is_write)
+{
+    uint8_t *pos = buf;
+
+    while (len) {
+        ssize_t ret;
+
+        if (is_write) {
+            ret = write(fd, pos, len);
+        } else {
+            ret = read(fd, pos, len);
+        }
+
+        if (ret < 0) {
+            if (errno == EINTR) {
+                continue;
+            }
+            return false;
+        }
+
+        if (ret == 0) {
+            return false;
+        }
+
+        pos += ret;
+        len -= ret;
+    }
+
+    return true;
+}
+
+static void axi_bus_close(AxiBusState *s)
+{
+    if (s->sockfd >= 0) {
+        close(s->sockfd);
+        s->sockfd = -1;
+    }
+}
+
+static bool axi_bus_connect(AxiBusState *s)
+{
+    struct sockaddr_un addr;
+    int fd;
+
+    if (s->sockfd >= 0) {
+        return true;
+    }
+
+    fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (fd < 0) {
+        goto fail;
+    }
+
+    memset(&addr, 0, sizeof(addr));
+    addr.sun_family = AF_UNIX;
+    if (g_strlcpy(addr.sun_path, s->socket_path, sizeof(addr.sun_path)) >=
+        sizeof(addr.sun_path)) {
+        errno = ENAMETOOLONG;
+        goto fail_close;
+    }
+
+    if (connect(fd, (struct sockaddr *)&addr, sizeof(addr)) < 0) {
+        goto fail_close;
+    }
+
+    s->sockfd = fd;
+    s->socket_error_reported = false;
+    return true;
+
+fail_close:
+    close(fd);
+fail:
+    if (!s->socket_error_reported) {
+        warn_report("%s: cannot connect to %s: %s",
+                    TYPE_AXI_BUS,
+                    s->socket_path,
+                    g_strerror(errno));
+        s->socket_error_reported = true;
+    }
+    return false;
+}
+
+static bool axi_bus_send_header(AxiBusState *s, AxiBusMsgKind kind,
+                                hwaddr addr, uint32_t len)
+{
+    AxiBusMsgHeader hdr = {
+        .kind = kind,
+        .flags = 0,
+        .window_id = 0,
+        .offset = addr,
+        .length = len,
+    };
+
+    if (!axi_bus_connect(s)) {
+        return false;
+    }
+
+    if (!axi_bus_io_all(s->sockfd, &hdr, sizeof(hdr), true)) {
+        axi_bus_close(s);
+        return false;
+    }
+
+    return true;
+}
+
+static bool axi_bus_send_reply(AxiBusState *s, AxiBusMsgKind kind,
+                               hwaddr addr, uint32_t len)
+{
+    AxiBusMsgHeader hdr = {
+        .kind = kind,
+        .flags = 0,
+        .window_id = 0,
+        .offset = addr,
+        .length = len,
+    };
+
+    return axi_bus_io_all(s->sockfd, &hdr, sizeof(hdr), true);
+}
+
+static void axi_bus_assert_irq(AxiBusState *s)
+{
+    if (!s->irq) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: backend requested IRQ %u but it is not wired\n",
+                      TYPE_AXI_BUS, s->irq_num);
+        return;
+    }
+
+    qemu_set_irq(s->irq, 1);
+}
+
+static bool axi_bus_service_backend(AxiBusState *s)
+{
+    AxiBusMsgHeader hdr;
+    g_autofree uint8_t *buf = NULL;
+    MemTxResult result;
+
+    for (;;) {
+        if (!axi_bus_io_all(s->sockfd, &hdr, sizeof(hdr), false)) {
+            axi_bus_close(s);
+            return false;
+        }
+
+        switch (hdr.kind) {
+        case AXI_BUS_MSG_ERROR:
+            return true;
+        case AXI_BUS_MSG_IRQ_ASSERT:
+            axi_bus_assert_irq(s);
+            break;
+        case AXI_BUS_MSG_IRQ_DEASSERT:
+            if (s->irq) {
+                qemu_set_irq(s->irq, 0);
+            }
+            break;
+        case AXI_BUS_MSG_DMA_READ:
+            if (!hdr.length) {
+                if (!axi_bus_send_reply(s, AXI_BUS_MSG_DMA_READ_REPLY,
+                                               hdr.offset, 0)) {
+                    axi_bus_close(s);
+                    return false;
+                }
+                break;
+            }
+            buf = g_malloc0(hdr.length);
+            result = address_space_rw(&address_space_memory, hdr.offset,
+                                      MEMTXATTRS_UNSPECIFIED, buf, hdr.length,
+                                      false);
+            if (result != MEMTX_OK ||
+                !axi_bus_send_reply(s, AXI_BUS_MSG_DMA_READ_REPLY,
+                                           hdr.offset, hdr.length) ||
+                !axi_bus_io_all(s->sockfd, buf, hdr.length, true)) {
+                axi_bus_close(s);
+                return false;
+            }
+            g_clear_pointer(&buf, g_free);
+            break;
+        case AXI_BUS_MSG_DMA_WRITE:
+            buf = g_malloc0(hdr.length);
+            if ((hdr.length &&
+                 !axi_bus_io_all(s->sockfd, buf, hdr.length, false)) ||
+                address_space_rw(&address_space_memory, hdr.offset,
+                                 MEMTXATTRS_UNSPECIFIED, buf, hdr.length,
+                                 true) != MEMTX_OK ||
+                !axi_bus_send_reply(s, AXI_BUS_MSG_ERROR, 0, 0)) {
+                axi_bus_close(s);
+                return false;
+            }
+            g_clear_pointer(&buf, g_free);
+            break;
+        default:
+            qemu_log_mask(LOG_GUEST_ERROR,
+                          "%s: unsupported backend message kind=%u\n",
+                          TYPE_AXI_BUS, hdr.kind);
+            axi_bus_close(s);
+            return false;
+        }
+    }
+}
+
+static uint64_t axi_bus_read(void *opaque, hwaddr addr, unsigned size)
+{
+    AxiBusState *s = opaque;
+    AxiBusMsgHeader reply;
+    uint64_t value = 0;
+
+    if (!axi_bus_send_header(s, AXI_BUS_MSG_MMIO_READ, addr, size)) {
+        return 0;
+    }
+
+    if (!axi_bus_io_all(s->sockfd, &reply, sizeof(reply), false)) {
+        axi_bus_close(s);
+        return 0;
+    }
+
+    if (reply.kind != AXI_BUS_MSG_MMIO_READ_REPLY || reply.length > 8) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: invalid read reply kind=%u length=%u\n",
+                      TYPE_AXI_BUS,
+                      reply.kind,
+                      reply.length);
+        axi_bus_close(s);
+        return 0;
+    }
+
+    if (reply.length &&
+        !axi_bus_io_all(s->sockfd, &value, reply.length, false)) {
+        axi_bus_close(s);
+        return 0;
+    }
+
+    return value;
+}
+
+static void axi_bus_write(void *opaque, hwaddr addr, uint64_t value,
+                          unsigned size)
+{
+    AxiBusState *s = opaque;
+
+    if (!axi_bus_send_header(s, AXI_BUS_MSG_MMIO_WRITE, addr, size)) {
+        return;
+    }
+
+    if (!axi_bus_io_all(s->sockfd, &value, size, true)) {
+        axi_bus_close(s);
+        return;
+    }
+
+    axi_bus_service_backend(s);
+}
+
+static const MemoryRegionOps axi_bus_ops = {
+    .read = axi_bus_read,
+    .write = axi_bus_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid.min_access_size = 1,
+    .valid.max_access_size = 8,
+    .impl.min_access_size = 1,
+    .impl.max_access_size = 8,
+};
+
+static bool axi_bus_parse_ram_access(AxiBusState *s, Error **errp)
+{
+    const char *mode = s->ram_access ?: "shared-mem";
+
+    if (!g_strcmp0(mode, "shared-mem")) {
+        s->ram_access_mode = AXI_BUS_RAM_ACCESS_SHARED_MEM;
+        return true;
+    }
+
+    if (!g_strcmp0(mode, "qemu-mediated")) {
+        s->ram_access_mode = AXI_BUS_RAM_ACCESS_QEMU_MEDIATED;
+        return true;
+    }
+
+    error_setg(errp, "invalid ram-access '%s'", mode);
+    return false;
+}
+
+static bool axi_bus_realize_x86(AxiBusState *s, Error **errp)
+{
+    Object *machine = qdev_get_machine();
+    X86MachineState *x86ms;
+
+    if (!object_dynamic_cast(machine, TYPE_X86_MACHINE)) {
+        return false;
+    }
+
+    x86ms = X86_MACHINE(machine);
+    if (!x86ms->ioapic2) {
+        error_setg(errp, "axi-bus requires microvm ioapic2=on");
+        return true;
+    }
+
+    if (s->irq_num < MICROVM_AXI_BUS_IRQ_BASE ||
+        s->irq_num >= MICROVM_AXI_BUS_IRQ_BASE + MICROVM_AXI_BUS_IRQ_COUNT) {
+        error_setg(errp, "axi-bus irq %u outside reserved range %u..%u",
+                   s->irq_num,
+                   MICROVM_AXI_BUS_IRQ_BASE,
+                   MICROVM_AXI_BUS_IRQ_BASE + MICROVM_AXI_BUS_IRQ_COUNT - 1);
+        return true;
+    }
+
+    if (x86ms->gsi && s->irq_num < 256) {
+        s->irq = x86ms->gsi[s->irq_num];
+    }
+    return true;
+}
+
+static void axi_bus_add_virt_fdt_node(VirtMachineState *vms, AxiBusState *s)
+{
+    MachineState *ms = MACHINE(vms);
+    g_autofree char *nodename = NULL;
+
+    if (!ms->fdt) {
+        return;
+    }
+
+    nodename = g_strdup_printf("/virtio_mmio@%" PRIx64, s->base);
+    qemu_fdt_add_subnode(ms->fdt, nodename);
+    qemu_fdt_setprop_string(ms->fdt, nodename, "compatible", "virtio,mmio");
+    qemu_fdt_setprop_sized_cells(ms->fdt, nodename, "reg",
+                                 2, s->base, 2, s->size);
+    qemu_fdt_setprop_cells(ms->fdt, nodename, "interrupts",
+                           GIC_FDT_IRQ_TYPE_SPI, s->irq_num,
+                           GIC_FDT_IRQ_FLAGS_EDGE_LO_HI);
+    qemu_fdt_setprop(ms->fdt, nodename, "dma-coherent", NULL, 0);
+}
+
+static bool axi_bus_realize_arm_virt(AxiBusState *s, Error **errp)
+{
+    Object *machine = qdev_get_machine();
+    VirtMachineState *vms;
+
+    if (!object_dynamic_cast(machine, TYPE_VIRT_MACHINE)) {
+        return false;
+    }
+
+    vms = VIRT_MACHINE(machine);
+    if (s->irq_num >= 256) {
+        error_setg(errp, "axi-bus irq %u outside supported GIC SPI range", s->irq_num);
+        return true;
+    }
+
+    s->irq = qdev_get_gpio_in(vms->gic, s->irq_num);
+    axi_bus_add_virt_fdt_node(vms, s);
+    return true;
+}
+
+static void axi_bus_realize(DeviceState *dev, Error **errp)
+{
+    AxiBusState *s = AXI_BUS(dev);
+    s->sockfd = -1;
+
+    if (!s->base) {
+        error_setg(errp, "base property is required");
+        return;
+    }
+
+    if (!s->size) {
+        error_setg(errp, "size property is required");
+        return;
+    }
+
+    if (!s->socket_path || !s->socket_path[0]) {
+        error_setg(errp, "socket property is required");
+        return;
+    }
+
+    if (!axi_bus_parse_ram_access(s, errp)) {
+        return;
+    }
+
+    if (!axi_bus_realize_x86(s, errp) &&
+        !axi_bus_realize_arm_virt(s, errp)) {
+        error_setg(errp, "axi-bus is only supported on x86 microvm and ARM virt machines");
+        return;
+    }
+
+    if (*errp) {
+        return;
+    }
+
+    memory_region_init_io(&s->mmio, OBJECT(dev), &axi_bus_ops, s,
+                          TYPE_AXI_BUS, s->size);
+    memory_region_add_subregion(get_system_memory(), s->base, &s->mmio);
+
+    warn_report("%s: mapped 0x%" PRIx64 " bytes at 0x%" PRIx64
+                ", irq=%u, socket=%s, ram-access=%s, target=%s; "
+                "external forwarding protocol enabled",
+                TYPE_AXI_BUS,
+                s->size,
+                s->base,
+                s->irq_num,
+                s->socket_path,
+                s->ram_access ?: "shared-mem",
+                s->target ?: "");
+}
+
+static const Property axi_bus_properties[] = {
+    DEFINE_PROP_UINT64("base", AxiBusState, base, 0),
+    DEFINE_PROP_UINT64("size", AxiBusState, size, 0),
+    DEFINE_PROP_UINT32("irq", AxiBusState, irq_num, 0),
+    DEFINE_PROP_STRING("socket", AxiBusState, socket_path),
+    DEFINE_PROP_STRING("ram-access", AxiBusState, ram_access),
+    DEFINE_PROP_STRING("target", AxiBusState, target),
+};
+
+static void axi_bus_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = axi_bus_realize;
+    dc->user_creatable = true;
+    device_class_set_props(dc, axi_bus_properties);
+    set_bit(DEVICE_CATEGORY_MISC, dc->categories);
+}
+
+static const TypeInfo axi_bus_info = {
+    .name = TYPE_AXI_BUS,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(AxiBusState),
+    .class_init = axi_bus_class_init,
+};
+
+static void axi_bus_register_types(void)
+{
+    type_register_static(&axi_bus_info);
+}
+
+type_init(axi_bus_register_types);
