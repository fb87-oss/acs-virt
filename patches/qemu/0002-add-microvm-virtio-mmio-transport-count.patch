diff --git a/hw/i386/microvm.c b/hw/i386/microvm.c
index bd657a9388..f442cd02d7 100644
--- a/hw/i386/microvm.c
+++ b/hw/i386/microvm.c
@@ -188,14 +188,13 @@ static void microvm_devices_init(MicrovmMachineState *mms)
 
     mms->virtio_irq_base = 5;
-    mms->virtio_num_transports = 8;
     if (x86ms->ioapic2) {
         mms->pcie_irq_base = 16;    /* 16 -> 19 */
-        /* use second ioapic (24 -> 47) for virtio-mmio irq lines */
-        mms->virtio_irq_base = IO_APIC_SECONDARY_IRQBASE;
-        mms->virtio_num_transports = IOAPIC_NUM_PINS;
+        /* reserve primary IO-APIC GSIs 16 -> 23 for project axi-bus devices */
+        mms->virtio_irq_base = MICROVM_AXI_BUS_IRQ_BASE +
+                               MICROVM_AXI_BUS_IRQ_COUNT;
     } else if (x86_machine_is_acpi_enabled(x86ms)) {
         mms->pcie_irq_base = 12;    /* 12 -> 15 */
         mms->virtio_irq_base = 16;  /* 16 -> 23 */
     }
 
     for (i = 0; i < mms->virtio_num_transports; i++) {
@@ -603,6 +604,24 @@ static bool microvm_machine_get_auto_kernel_cmdline(Object *obj, Error **errp)
     return mms->auto_kernel_cmdline;
 }
 
+static void microvm_machine_get_virtio_mmio_transports(Object *obj, Visitor *v,
+                                                       const char *name,
+                                                       void *opaque,
+                                                       Error **errp)
+{
+    MicrovmMachineState *mms = MICROVM_MACHINE(obj);
+    visit_type_uint32(v, name, &mms->virtio_num_transports, errp);
+}
+
+static void microvm_machine_set_virtio_mmio_transports(Object *obj, Visitor *v,
+                                                       const char *name,
+                                                       void *opaque,
+                                                       Error **errp)
+{
+    MicrovmMachineState *mms = MICROVM_MACHINE(obj);
+    visit_type_uint32(v, name, &mms->virtio_num_transports, errp);
+}
+
 static void microvm_machine_set_auto_kernel_cmdline(Object *obj, bool value,
                                                     Error **errp)
 {
@@ -625,6 +644,7 @@ static void microvm_machine_initfn(Object *obj)
     mms->ioapic2 = ON_OFF_AUTO_AUTO;
     mms->isa_serial = true;
     mms->option_roms = true;
+    mms->virtio_num_transports = 0;
     mms->auto_kernel_cmdline = true;
 }
 
@@ -713,8 +733,18 @@ static void microvm_class_init(ObjectClass *oc, const void *data)
                                    microvm_machine_get_auto_kernel_cmdline,
                                    microvm_machine_set_auto_kernel_cmdline);
     object_class_property_set_description(oc,
         MICROVM_MACHINE_AUTO_KERNEL_CMDLINE,
         "Set off to disable adding virtio-mmio devices to the kernel cmdline");
+
+    object_class_property_add(oc, MICROVM_MACHINE_VIRTIO_MMIO_TRANSPORTS,
+                              "uint32",
+                              microvm_machine_get_virtio_mmio_transports,
+                              microvm_machine_set_virtio_mmio_transports,
+                              NULL, NULL);
+    object_class_property_set_description(oc,
+        MICROVM_MACHINE_VIRTIO_MMIO_TRANSPORTS,
+        "Number of built-in virtio-mmio transports");
 
     machine_class_allow_dynamic_sysbus_dev(mc, TYPE_RAMFB_DEVICE);
+    machine_class_allow_dynamic_sysbus_dev(mc, "axi-bus");
 
diff --git a/include/hw/i386/microvm.h b/include/hw/i386/microvm.h
index 2ad87ef551..b194649b4d 100644
--- a/include/hw/i386/microvm.h
+++ b/include/hw/i386/microvm.h
@@ -61,6 +61,10 @@
 #define MICROVM_XHCI_BASE     0xfe900000
 #define MICROVM_XHCI_IRQ      10
 
+/* Project-reserved primary IO-APIC range for externally-backed axi-bus MMIO. */
+#define MICROVM_AXI_BUS_IRQ_BASE  16
+#define MICROVM_AXI_BUS_IRQ_COUNT 8
+
 #define PCIE_MMIO_BASE        0xc0000000
 #define PCIE_MMIO_SIZE        0x20000000
 #define PCIE_ECAM_BASE        0xe0000000
@@ -73,6 +77,7 @@
 #define MICROVM_MACHINE_ISA_SERIAL          "isa-serial"
 #define MICROVM_MACHINE_OPTION_ROMS         "x-option-roms"
 #define MICROVM_MACHINE_AUTO_KERNEL_CMDLINE "auto-kernel-cmdline"
+#define MICROVM_MACHINE_VIRTIO_MMIO_TRANSPORTS "virtio-mmio-transports"
 
 struct MicrovmMachineClass {
     X86MachineClass parent;
