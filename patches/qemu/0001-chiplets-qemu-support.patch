diff --git a/hw/misc/axi.c b/hw/misc/axi.c
new file mode 100644
index 0000000000..14521bdf7f
--- /dev/null
+++ b/hw/misc/axi.c
@@ -0,0 +1,929 @@
+/*
+ * Emulated AXI fabric proxy device.
+ *
+ * This device intentionally does not implement virtio or any other endpoint
+ * protocol. It exposes a configurable MMIO window and is the QEMU-side anchor
+ * for forwarding register accesses to an external device model.
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "system/address-spaces.h"
+#include "system/device_tree.h"
+#include "system/memory.h"
+#include "hw/arm/fdt.h"
+#include "hw/arm/virt.h"
+#include "hw/i386/microvm.h"
+#include "hw/i386/x86.h"
+#include "hw/irq.h"
+#include "hw/qdev-properties.h"
+#include "hw/sysbus.h"
+#include "qemu/error-report.h"
+#include "qemu/log.h"
+#include "qemu/main-loop.h"
+#include "qemu/module.h"
+#include "qom/object.h"
+#include "system/hostmem.h"
+#include <linux/virtio_mmio.h>
+#include <sys/socket.h>
+#include <sys/un.h>
+#include <unistd.h>
+
+#define TYPE_AXI "axi"
+OBJECT_DECLARE_SIMPLE_TYPE(AxiState, AXI)
+
+#define AXI_CONTROL_IRQ_OFFSET 0x200
+#define AXI_UIO_NOTIFY_DELAY_US 50000
+#define AXI_UIO_IRQ_PULSE_US 10000
+
+typedef enum AxiMode {
+    AXI_MODE_SOCKET,
+    AXI_MODE_UIO,
+} AxiMode;
+
+typedef enum AxiRole {
+    AXI_ROLE_SLAVE,
+    AXI_ROLE_MASTER,
+} AxiRole;
+
+typedef enum AxiRamAccess {
+    AXI_RAM_ACCESS_SHARED_MEM,
+    AXI_RAM_ACCESS_QEMU_MEDIATED,
+} AxiRamAccess;
+
+typedef enum AxiMsgKind {
+    AXI_MSG_HELLO = 1,
+    AXI_MSG_MEM_REGION = 2,
+    AXI_MSG_MMIO_READ = 3,
+    AXI_MSG_MMIO_READ_REPLY = 4,
+    AXI_MSG_MMIO_WRITE = 5,
+    AXI_MSG_IRQ_ASSERT = 6,
+    AXI_MSG_IRQ_DEASSERT = 7,
+    AXI_MSG_DMA_READ = 8,
+    AXI_MSG_DMA_READ_REPLY = 9,
+    AXI_MSG_DMA_WRITE = 10,
+    AXI_MSG_FRONTEND_NOTIFY = 100,
+    AXI_MSG_FRONTEND_IRQ_ASSERT = 101,
+    AXI_MSG_FRONTEND_IRQ_DEASSERT = 102,
+    AXI_MSG_FRONTEND_NOTIFY_ACK = 103,
+    AXI_MSG_ERROR = 0xffff,
+} AxiMsgKind;
+
+typedef struct AxiMsgHeader {
+    uint16_t kind;
+    uint16_t flags;
+    uint32_t window_id;
+    uint64_t offset;
+    uint32_t length;
+} AxiMsgHeader;
+
+struct AxiState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion mmio;
+    MemoryRegion dma_alias;
+    HostMemoryBackend *hostmem;
+    HostMemoryBackend *dma_memdev;
+    uint8_t *shared_mmio;
+    uint64_t base;
+    uint64_t size;
+    uint64_t dma_base;
+    uint64_t dma_size;
+    uint32_t irq_num;
+    uint32_t notify_delay_us;
+    char *socket_path;
+    char *mode;
+    char *role;
+    char *control_socket_path;
+    char *ram_access;
+    char *target;
+    AxiMode mode_value;
+    AxiRole role_value;
+    AxiRamAccess ram_access_mode;
+    int sockfd;
+    int listen_fd;
+    int control_fd;
+    GMutex notify_lock;
+    GCond notify_cond;
+    uint32_t notify_seq;
+    uint32_t notify_ack_seq;
+    bool socket_error_reported;
+    bool notify_ack;
+    qemu_irq irq;
+};
+
+static bool axi_control_send(AxiState *s, AxiMsgKind kind);
+static bool axi_io_all(int fd, void *buf, size_t len, bool is_write);
+static void axi_control_close(AxiState *s);
+static void axi_control_read(void *opaque);
+
+static void axi_wait_for_notify_ack(AxiState *s)
+{
+    gint64 deadline;
+    GPollFD pfd;
+
+    if (s->control_fd < 0) {
+        g_usleep(s->notify_delay_us);
+        return;
+    }
+
+    qemu_set_fd_handler(s->control_fd, NULL, NULL, NULL);
+    if (!axi_control_send(s, AXI_MSG_FRONTEND_NOTIFY)) {
+        qemu_set_fd_handler(s->control_fd, axi_control_read, NULL, s);
+        g_usleep(s->notify_delay_us);
+        return;
+    }
+
+    deadline = g_get_monotonic_time() + s->notify_delay_us;
+    pfd.fd = s->control_fd;
+    pfd.events = G_IO_IN;
+    while (g_get_monotonic_time() < deadline) {
+        AxiMsgHeader hdr;
+        gint64 remaining = deadline - g_get_monotonic_time();
+        int ret;
+
+        pfd.revents = 0;
+        ret = g_poll(&pfd, 1, MAX(1, (int)((remaining + 999) / 1000)));
+        if (ret <= 0) {
+            break;
+        }
+        if (!(pfd.revents & G_IO_IN) ||
+            !axi_io_all(s->control_fd, &hdr, sizeof(hdr), false)) {
+            axi_control_close(s);
+            break;
+        }
+        if (hdr.kind == AXI_MSG_FRONTEND_NOTIFY_ACK) {
+            break;
+        }
+        switch (hdr.kind) {
+        case AXI_MSG_FRONTEND_IRQ_ASSERT:
+            if (s->irq) {
+                qemu_set_irq(s->irq, 1);
+            }
+            break;
+        case AXI_MSG_FRONTEND_IRQ_DEASSERT:
+            if (s->irq) {
+                qemu_set_irq(s->irq, 0);
+            }
+            break;
+        default:
+            qemu_log_mask(LOG_GUEST_ERROR,
+                          "%s: unsupported control message kind=%u\n", TYPE_AXI,
+                          hdr.kind);
+            break;
+        }
+    }
+    if (s->control_fd >= 0) {
+        qemu_set_fd_handler(s->control_fd, axi_control_read, NULL, s);
+    }
+}
+
+static bool axi_io_all(int fd, void *buf, size_t len, bool is_write)
+{
+    uint8_t *pos = buf;
+
+    while (len) {
+        ssize_t ret;
+
+        if (is_write) {
+            ret = write(fd, pos, len);
+        } else {
+            ret = read(fd, pos, len);
+        }
+
+        if (ret < 0) {
+            if (errno == EINTR) {
+                continue;
+            }
+            return false;
+        }
+
+        if (ret == 0) {
+            return false;
+        }
+
+        pos += ret;
+        len -= ret;
+    }
+
+    return true;
+}
+
+static void axi_close(AxiState *s)
+{
+    if (s->sockfd >= 0) {
+        close(s->sockfd);
+        s->sockfd = -1;
+    }
+}
+
+static void axi_control_close(AxiState *s)
+{
+    if (s->control_fd >= 0) {
+        qemu_set_fd_handler(s->control_fd, NULL, NULL, NULL);
+        close(s->control_fd);
+        s->control_fd = -1;
+    }
+}
+
+static void axi_control_read(void *opaque)
+{
+    AxiState *s = opaque;
+    AxiMsgHeader hdr;
+
+    if (!axi_io_all(s->control_fd, &hdr, sizeof(hdr), false)) {
+        axi_control_close(s);
+        return;
+    }
+
+    switch (hdr.kind) {
+    case AXI_MSG_FRONTEND_NOTIFY:
+        if (s->irq) {
+            qemu_set_irq(s->irq, 1);
+            g_usleep(AXI_UIO_IRQ_PULSE_US);
+            qemu_set_irq(s->irq, 0);
+        }
+        break;
+    case AXI_MSG_FRONTEND_IRQ_ASSERT:
+        if (s->irq) {
+            qemu_set_irq(s->irq, 1);
+        }
+        break;
+    case AXI_MSG_FRONTEND_IRQ_DEASSERT:
+        if (s->irq) {
+            qemu_set_irq(s->irq, 0);
+        }
+        break;
+    case AXI_MSG_FRONTEND_NOTIFY_ACK:
+        g_mutex_lock(&s->notify_lock);
+        s->notify_ack_seq++;
+        g_cond_broadcast(&s->notify_cond);
+        g_mutex_unlock(&s->notify_lock);
+        break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: unsupported control message kind=%u\n", TYPE_AXI,
+                      hdr.kind);
+        break;
+    }
+}
+
+static void axi_control_accept(void *opaque)
+{
+    AxiState *s = opaque;
+    int fd = accept(s->listen_fd, NULL, NULL);
+
+    if (fd < 0) {
+        return;
+    }
+    axi_control_close(s);
+    s->control_fd = fd;
+    qemu_set_fd_handler(s->control_fd, axi_control_read, NULL, s);
+}
+
+static bool axi_control_listen(AxiState *s, Error **errp)
+{
+    struct sockaddr_un addr;
+
+    s->listen_fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (s->listen_fd < 0) {
+        error_setg_errno(errp, errno, "axi cannot create control socket");
+        return false;
+    }
+    unlink(s->control_socket_path);
+    memset(&addr, 0, sizeof(addr));
+    addr.sun_family = AF_UNIX;
+    if (g_strlcpy(addr.sun_path, s->control_socket_path, sizeof(addr.sun_path)) >=
+        sizeof(addr.sun_path)) {
+        error_setg(errp, "axi control socket path too long: %s", s->control_socket_path);
+        return false;
+    }
+    if (bind(s->listen_fd, (struct sockaddr *)&addr, sizeof(addr)) < 0 ||
+        listen(s->listen_fd, 1) < 0) {
+        error_setg_errno(errp, errno, "axi cannot listen on control socket");
+        return false;
+    }
+    qemu_set_fd_handler(s->listen_fd, axi_control_accept, NULL, s);
+    return true;
+}
+
+static bool axi_control_connect(AxiState *s, Error **errp)
+{
+    struct sockaddr_un addr;
+
+    s->control_fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (s->control_fd < 0) {
+        error_setg_errno(errp, errno, "axi cannot create control socket");
+        return false;
+    }
+    memset(&addr, 0, sizeof(addr));
+    addr.sun_family = AF_UNIX;
+    if (g_strlcpy(addr.sun_path, s->control_socket_path, sizeof(addr.sun_path)) >=
+        sizeof(addr.sun_path)) {
+        error_setg(errp, "axi control socket path too long: %s", s->control_socket_path);
+        return false;
+    }
+    if (connect(s->control_fd, (struct sockaddr *)&addr, sizeof(addr)) < 0) {
+        error_setg_errno(errp, errno, "axi cannot connect control socket");
+        return false;
+    }
+    qemu_set_fd_handler(s->control_fd, axi_control_read, NULL, s);
+    return true;
+}
+
+static bool axi_control_send(AxiState *s, AxiMsgKind kind)
+{
+    AxiMsgHeader hdr = {
+        .kind = kind,
+        .flags = 0,
+        .window_id = 0,
+        .offset = 0,
+        .length = 0,
+    };
+
+    if (s->control_fd < 0) {
+        return false;
+    }
+    if (!axi_io_all(s->control_fd, &hdr, sizeof(hdr), true)) {
+        axi_control_close(s);
+        return false;
+    }
+    return true;
+}
+
+static bool axi_connect(AxiState *s)
+{
+    struct sockaddr_un addr;
+    int fd;
+
+    if (s->sockfd >= 0) {
+        return true;
+    }
+
+    fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (fd < 0) {
+        goto fail;
+    }
+
+    memset(&addr, 0, sizeof(addr));
+    addr.sun_family = AF_UNIX;
+    if (g_strlcpy(addr.sun_path, s->socket_path, sizeof(addr.sun_path)) >=
+        sizeof(addr.sun_path)) {
+        errno = ENAMETOOLONG;
+        goto fail_close;
+    }
+
+    if (connect(fd, (struct sockaddr *)&addr, sizeof(addr)) < 0) {
+        goto fail_close;
+    }
+
+    s->sockfd = fd;
+    s->socket_error_reported = false;
+    return true;
+
+fail_close:
+    close(fd);
+fail:
+    if (!s->socket_error_reported) {
+        warn_report("%s: cannot connect to %s: %s",
+                    TYPE_AXI,
+                    s->socket_path,
+                    g_strerror(errno));
+        s->socket_error_reported = true;
+    }
+    return false;
+}
+
+static bool axi_send_header(AxiState *s, AxiMsgKind kind,
+                                hwaddr addr, uint32_t len)
+{
+    AxiMsgHeader hdr = {
+        .kind = kind,
+        .flags = 0,
+        .window_id = 0,
+        .offset = addr,
+        .length = len,
+    };
+
+    if (!axi_connect(s)) {
+        return false;
+    }
+
+    if (!axi_io_all(s->sockfd, &hdr, sizeof(hdr), true)) {
+        axi_close(s);
+        return false;
+    }
+
+    return true;
+}
+
+static bool axi_send_reply(AxiState *s, AxiMsgKind kind,
+                               hwaddr addr, uint32_t len)
+{
+    AxiMsgHeader hdr = {
+        .kind = kind,
+        .flags = 0,
+        .window_id = 0,
+        .offset = addr,
+        .length = len,
+    };
+
+    return axi_io_all(s->sockfd, &hdr, sizeof(hdr), true);
+}
+
+static void axi_assert_irq(AxiState *s)
+{
+    if (!s->irq) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: backend requested IRQ %u but it is not wired\n",
+                      TYPE_AXI, s->irq_num);
+        return;
+    }
+
+    qemu_set_irq(s->irq, 1);
+}
+
+static bool axi_service_backend(AxiState *s)
+{
+    AxiMsgHeader hdr;
+    g_autofree uint8_t *buf = NULL;
+    MemTxResult result;
+
+    for (;;) {
+        if (!axi_io_all(s->sockfd, &hdr, sizeof(hdr), false)) {
+            axi_close(s);
+            return false;
+        }
+
+        switch (hdr.kind) {
+        case AXI_MSG_ERROR:
+            return true;
+        case AXI_MSG_IRQ_ASSERT:
+            axi_assert_irq(s);
+            break;
+        case AXI_MSG_IRQ_DEASSERT:
+            if (s->irq) {
+                qemu_set_irq(s->irq, 0);
+            }
+            break;
+        case AXI_MSG_DMA_READ:
+            if (!hdr.length) {
+                if (!axi_send_reply(s, AXI_MSG_DMA_READ_REPLY,
+                                               hdr.offset, 0)) {
+                    axi_close(s);
+                    return false;
+                }
+                break;
+            }
+            buf = g_malloc0(hdr.length);
+            result = address_space_rw(&address_space_memory, hdr.offset,
+                                      MEMTXATTRS_UNSPECIFIED, buf, hdr.length,
+                                      false);
+            if (result != MEMTX_OK ||
+                !axi_send_reply(s, AXI_MSG_DMA_READ_REPLY,
+                                           hdr.offset, hdr.length) ||
+                !axi_io_all(s->sockfd, buf, hdr.length, true)) {
+                axi_close(s);
+                return false;
+            }
+            g_clear_pointer(&buf, g_free);
+            break;
+        case AXI_MSG_DMA_WRITE:
+            buf = g_malloc0(hdr.length);
+            if ((hdr.length &&
+                 !axi_io_all(s->sockfd, buf, hdr.length, false)) ||
+                address_space_rw(&address_space_memory, hdr.offset,
+                                 MEMTXATTRS_UNSPECIFIED, buf, hdr.length,
+                                 true) != MEMTX_OK ||
+                !axi_send_reply(s, AXI_MSG_ERROR, 0, 0)) {
+                axi_close(s);
+                return false;
+            }
+            g_clear_pointer(&buf, g_free);
+            break;
+        default:
+            qemu_log_mask(LOG_GUEST_ERROR,
+                          "%s: unsupported backend message kind=%u\n",
+                          TYPE_AXI, hdr.kind);
+            axi_close(s);
+            return false;
+        }
+    }
+}
+
+static uint64_t axi_read(void *opaque, hwaddr addr, unsigned size)
+{
+    AxiState *s = opaque;
+    AxiMsgHeader reply;
+    uint64_t value = 0;
+
+    if (!axi_send_header(s, AXI_MSG_MMIO_READ, addr, size)) {
+        return 0;
+    }
+
+    if (!axi_io_all(s->sockfd, &reply, sizeof(reply), false)) {
+        axi_close(s);
+        return 0;
+    }
+
+    if (reply.kind != AXI_MSG_MMIO_READ_REPLY || reply.length > 8) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: invalid read reply kind=%u length=%u\n",
+                      TYPE_AXI,
+                      reply.kind,
+                      reply.length);
+        axi_close(s);
+        return 0;
+    }
+
+    if (reply.length &&
+        !axi_io_all(s->sockfd, &value, reply.length, false)) {
+        axi_close(s);
+        return 0;
+    }
+
+    return value;
+}
+
+static void axi_write(void *opaque, hwaddr addr, uint64_t value,
+                          unsigned size)
+{
+    AxiState *s = opaque;
+
+    if (!axi_send_header(s, AXI_MSG_MMIO_WRITE, addr, size)) {
+        return;
+    }
+
+    if (!axi_io_all(s->sockfd, &value, size, true)) {
+        axi_close(s);
+        return;
+    }
+
+    axi_service_backend(s);
+}
+
+static uint64_t axi_uio_read(void *opaque, hwaddr addr, unsigned size)
+{
+    AxiState *s = opaque;
+    uint64_t value = 0;
+
+    if (addr + size > s->size) {
+        return 0;
+    }
+    if (s->role_value == AXI_ROLE_SLAVE) {
+        if (s->notify_ack) {
+            axi_wait_for_notify_ack(s);
+        } else {
+            axi_control_send(s, AXI_MSG_FRONTEND_NOTIFY);
+            g_usleep(s->notify_delay_us);
+        }
+    }
+    memcpy(&value, s->shared_mmio + addr, size);
+    return value;
+}
+
+static void axi_uio_write(void *opaque, hwaddr addr, uint64_t value,
+                          unsigned size)
+{
+    AxiState *s = opaque;
+
+    if (addr + size > s->size) {
+        return;
+    }
+    memcpy(s->shared_mmio + addr, &value, size);
+
+    if (s->role_value == AXI_ROLE_SLAVE &&
+        addr == VIRTIO_MMIO_QUEUE_SEL) {
+        static const hwaddr queue_offsets[] = {
+            VIRTIO_MMIO_QUEUE_NUM,        VIRTIO_MMIO_QUEUE_READY,
+            VIRTIO_MMIO_QUEUE_DESC_LOW,   VIRTIO_MMIO_QUEUE_DESC_HIGH,
+            VIRTIO_MMIO_QUEUE_AVAIL_LOW,  VIRTIO_MMIO_QUEUE_AVAIL_HIGH,
+            VIRTIO_MMIO_QUEUE_USED_LOW,   VIRTIO_MMIO_QUEUE_USED_HIGH,
+        };
+        uint32_t zero = 0;
+
+        for (size_t i = 0; i < G_N_ELEMENTS(queue_offsets); i++) {
+            if (queue_offsets[i] + sizeof(zero) <= s->size) {
+                memcpy(s->shared_mmio + queue_offsets[i], &zero, sizeof(zero));
+            }
+        }
+    }
+
+    if (s->role_value == AXI_ROLE_SLAVE) {
+        if (s->notify_ack) {
+            axi_wait_for_notify_ack(s);
+        } else {
+            axi_control_send(s, AXI_MSG_FRONTEND_NOTIFY);
+            g_usleep(s->notify_delay_us);
+        }
+    } else if (s->role_value == AXI_ROLE_MASTER &&
+               addr == AXI_CONTROL_IRQ_OFFSET) {
+        axi_control_send(s, value ? AXI_MSG_FRONTEND_IRQ_ASSERT
+                                  : AXI_MSG_FRONTEND_IRQ_DEASSERT);
+        axi_control_send(s, AXI_MSG_FRONTEND_NOTIFY_ACK);
+    }
+}
+
+static const MemoryRegionOps axi_ops = {
+    .read = axi_read,
+    .write = axi_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid.min_access_size = 1,
+    .valid.max_access_size = 8,
+    .impl.min_access_size = 1,
+    .impl.max_access_size = 8,
+};
+
+static const MemoryRegionOps axi_uio_ops = {
+    .read = axi_uio_read,
+    .write = axi_uio_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid.min_access_size = 1,
+    .valid.max_access_size = 8,
+    .impl.min_access_size = 1,
+    .impl.max_access_size = 8,
+};
+
+static bool axi_parse_mode(AxiState *s, Error **errp)
+{
+    const char *mode = s->mode ?: "socket";
+    const char *role = s->role ?: "slave";
+
+    if (!g_strcmp0(mode, "socket")) {
+        s->mode_value = AXI_MODE_SOCKET;
+    } else if (!g_strcmp0(mode, "uio")) {
+        s->mode_value = AXI_MODE_UIO;
+    } else {
+        error_setg(errp, "invalid axi mode '%s'", mode);
+        return false;
+    }
+
+    if (!g_strcmp0(role, "slave")) {
+        s->role_value = AXI_ROLE_SLAVE;
+    } else if (!g_strcmp0(role, "master")) {
+        s->role_value = AXI_ROLE_MASTER;
+    } else {
+        error_setg(errp, "invalid axi role '%s'", role);
+        return false;
+    }
+    return true;
+}
+
+static bool axi_parse_ram_access(AxiState *s, Error **errp)
+{
+    const char *mode = s->ram_access ?: "shared-mem";
+
+    if (!g_strcmp0(mode, "shared-mem")) {
+        s->ram_access_mode = AXI_RAM_ACCESS_SHARED_MEM;
+        return true;
+    }
+
+    if (!g_strcmp0(mode, "qemu-mediated")) {
+        s->ram_access_mode = AXI_RAM_ACCESS_QEMU_MEDIATED;
+        return true;
+    }
+
+    error_setg(errp, "invalid ram-access '%s'", mode);
+    return false;
+}
+
+static bool axi_realize_x86(AxiState *s, Error **errp)
+{
+    Object *machine = qdev_get_machine();
+    X86MachineState *x86ms;
+
+    if (!object_dynamic_cast(machine, TYPE_X86_MACHINE)) {
+        return false;
+    }
+
+    x86ms = X86_MACHINE(machine);
+    if (!x86ms->ioapic2) {
+        error_setg(errp, "axi requires microvm ioapic2=on");
+        return true;
+    }
+
+    if (s->irq_num < MICROVM_AXI_IRQ_BASE ||
+        s->irq_num >= MICROVM_AXI_IRQ_BASE + MICROVM_AXI_IRQ_COUNT) {
+        error_setg(errp, "axi irq %u outside reserved range %u..%u",
+                   s->irq_num,
+                   MICROVM_AXI_IRQ_BASE,
+                   MICROVM_AXI_IRQ_BASE + MICROVM_AXI_IRQ_COUNT - 1);
+        return true;
+    }
+
+    if (x86ms->gsi && s->irq_num < 256) {
+        s->irq = x86ms->gsi[s->irq_num];
+    }
+    return true;
+}
+
+static void axi_add_virt_fdt_node(VirtMachineState *vms, AxiState *s)
+{
+    MachineState *ms = MACHINE(vms);
+    g_autofree char *nodename = NULL;
+
+    if (s->role_value != AXI_ROLE_SLAVE || !ms->fdt) {
+        return;
+    }
+
+    nodename = g_strdup_printf("/virtio_mmio@%" PRIx64, s->base);
+    qemu_fdt_add_subnode(ms->fdt, nodename);
+    qemu_fdt_setprop_string(ms->fdt, nodename, "compatible", "virtio,mmio");
+    qemu_fdt_setprop_sized_cells(ms->fdt, nodename, "reg",
+                                 2, s->base, 2, s->size);
+    qemu_fdt_setprop_cells(ms->fdt, nodename, "interrupts",
+                           GIC_FDT_IRQ_TYPE_SPI, s->irq_num,
+                           GIC_FDT_IRQ_FLAGS_EDGE_LO_HI);
+    qemu_fdt_setprop(ms->fdt, nodename, "dma-coherent", NULL, 0);
+}
+
+static void axi_add_virt_uio_fdt_node(VirtMachineState *vms, AxiState *s)
+{
+    MachineState *ms = MACHINE(vms);
+    g_autofree char *nodename = NULL;
+
+    if (s->mode_value != AXI_MODE_UIO || s->role_value != AXI_ROLE_MASTER ||
+        !ms->fdt) {
+        return;
+    }
+
+    nodename = g_strdup_printf("/chiplets_uio@%" PRIx64, s->base);
+    qemu_fdt_add_subnode(ms->fdt, nodename);
+    qemu_fdt_setprop_string(ms->fdt, nodename, "compatible", "chiplets,uio");
+    if (s->dma_size) {
+        qemu_fdt_setprop_sized_cells(ms->fdt, nodename, "reg",
+                                     2, s->base, 2, s->size,
+                                     2, s->dma_base, 2, s->dma_size);
+    } else {
+        qemu_fdt_setprop_sized_cells(ms->fdt, nodename, "reg",
+                                     2, s->base, 2, s->size);
+    }
+    qemu_fdt_setprop_cells(ms->fdt, nodename, "interrupts",
+                           GIC_FDT_IRQ_TYPE_SPI, s->irq_num,
+                           GIC_FDT_IRQ_FLAGS_EDGE_LO_HI);
+    qemu_fdt_setprop(ms->fdt, nodename, "dma-coherent", NULL, 0);
+}
+
+static bool axi_realize_arm_virt(AxiState *s, Error **errp)
+{
+    Object *machine = qdev_get_machine();
+    VirtMachineState *vms;
+
+    if (!object_dynamic_cast(machine, TYPE_VIRT_MACHINE)) {
+        return false;
+    }
+
+    vms = VIRT_MACHINE(machine);
+    if (s->irq_num >= 256) {
+        error_setg(errp, "axi irq %u outside supported GIC SPI range", s->irq_num);
+        return true;
+    }
+
+    s->irq = qdev_get_gpio_in(vms->gic, s->irq_num);
+    axi_add_virt_fdt_node(vms, s);
+    axi_add_virt_uio_fdt_node(vms, s);
+    return true;
+}
+
+static void axi_realize(DeviceState *dev, Error **errp)
+{
+    AxiState *s = AXI(dev);
+    s->sockfd = -1;
+    s->listen_fd = -1;
+    s->control_fd = -1;
+    g_mutex_init(&s->notify_lock);
+    g_cond_init(&s->notify_cond);
+
+    if (!s->base) {
+        error_setg(errp, "base property is required");
+        return;
+    }
+
+    if (!s->size) {
+        error_setg(errp, "size property is required");
+        return;
+    }
+
+    if (!axi_parse_mode(s, errp)) {
+        return;
+    }
+
+    if (s->mode_value == AXI_MODE_SOCKET &&
+        (!s->socket_path || !s->socket_path[0])) {
+        error_setg(errp, "socket property is required");
+        return;
+    }
+
+    if (s->mode_value == AXI_MODE_UIO) {
+        if (!s->hostmem) {
+            error_setg(errp, "axi uio mode requires memdev");
+            return;
+        }
+        if (!s->control_socket_path || !s->control_socket_path[0]) {
+            error_setg(errp, "axi uio mode requires control-socket");
+            return;
+        }
+    }
+
+    if (!axi_parse_ram_access(s, errp)) {
+        return;
+    }
+
+    if (!axi_realize_x86(s, errp) &&
+        !axi_realize_arm_virt(s, errp)) {
+        error_setg(errp, "axi is only supported on x86 microvm and ARM virt machines");
+        return;
+    }
+
+    if (*errp) {
+        return;
+    }
+
+    if (s->mode_value == AXI_MODE_UIO) {
+        MemoryRegion *host_mr = host_memory_backend_get_memory(s->hostmem);
+        uint64_t host_size = memory_region_size(host_mr);
+
+        if (host_size < s->size) {
+            error_setg(errp, "axi memdev too small: 0x%" PRIx64 " < 0x%" PRIx64,
+                       host_size, s->size);
+            return;
+        }
+        s->shared_mmio = memory_region_get_ram_ptr(host_mr);
+        memory_region_init_io(&s->mmio, OBJECT(dev), &axi_uio_ops, s,
+                              TYPE_AXI, s->size);
+        if (s->role_value == AXI_ROLE_SLAVE) {
+            if (!axi_control_listen(s, errp)) {
+                return;
+            }
+        } else if (!axi_control_connect(s, errp)) {
+            return;
+        }
+    } else {
+        memory_region_init_io(&s->mmio, OBJECT(dev), &axi_ops, s,
+                              TYPE_AXI, s->size);
+    }
+    memory_region_add_subregion(get_system_memory(), s->base, &s->mmio);
+
+    if (s->mode_value == AXI_MODE_UIO && s->dma_memdev && s->dma_size) {
+        MemoryRegion *dma_mr = host_memory_backend_get_memory(s->dma_memdev);
+        memory_region_init_alias(&s->dma_alias, OBJECT(dev), "axi-dma", dma_mr,
+                                 0, s->dma_size);
+        memory_region_add_subregion(get_system_memory(), s->dma_base,
+                                    &s->dma_alias);
+    }
+
+    warn_report("%s: mapped 0x%" PRIx64 " bytes at 0x%" PRIx64
+                ", irq=%u, socket=%s, ram-access=%s, target=%s; "
+                "external forwarding protocol enabled",
+                TYPE_AXI,
+                s->size,
+                s->base,
+                s->irq_num,
+                s->socket_path,
+                s->ram_access ?: "shared-mem",
+                s->target ?: "");
+}
+
+static const Property axi_properties[] = {
+    DEFINE_PROP_UINT64("base", AxiState, base, 0),
+    DEFINE_PROP_UINT64("size", AxiState, size, 0),
+    DEFINE_PROP_UINT64("dma-base", AxiState, dma_base, 0),
+    DEFINE_PROP_UINT64("dma-size", AxiState, dma_size, 0),
+    DEFINE_PROP_UINT32("irq", AxiState, irq_num, 0),
+    DEFINE_PROP_UINT32("notify-delay-us", AxiState, notify_delay_us,
+                       AXI_UIO_NOTIFY_DELAY_US),
+    DEFINE_PROP_STRING("socket", AxiState, socket_path),
+    DEFINE_PROP_STRING("mode", AxiState, mode),
+    DEFINE_PROP_STRING("role", AxiState, role),
+    DEFINE_PROP_STRING("control-socket", AxiState, control_socket_path),
+    DEFINE_PROP_STRING("ram-access", AxiState, ram_access),
+    DEFINE_PROP_STRING("target", AxiState, target),
+    DEFINE_PROP_LINK("memdev", AxiState, hostmem, TYPE_MEMORY_BACKEND,
+                     HostMemoryBackend *),
+    DEFINE_PROP_LINK("dma-memdev", AxiState, dma_memdev, TYPE_MEMORY_BACKEND,
+                     HostMemoryBackend *),
+    DEFINE_PROP_BOOL("notify-ack", AxiState, notify_ack, true),
+};
+
+static void axi_class_init(ObjectClass *klass, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = axi_realize;
+    dc->user_creatable = true;
+    device_class_set_props(dc, axi_properties);
+    set_bit(DEVICE_CATEGORY_MISC, dc->categories);
+}
+
+static const TypeInfo axi_info = {
+    .name = TYPE_AXI,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(AxiState),
+    .class_init = axi_class_init,
+};
+
+static void axi_register_types(void)
+{
+    type_register_static(&axi_info);
+}
+type_init(axi_register_types);
